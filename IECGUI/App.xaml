<Application x:Class="IECGUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IECGUI.ViewModel"
             xmlns:view="clr-namespace:IECGUI.View"
             xmlns:controls="clr-namespace:IECGUI.Controls"
             xmlns:local="clr-namespace:IECGUI"
             >
    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary  Source="Resources/Icons.xaml"/>
                <ResourceDictionary  Source="Resources/ButtonStyle.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <view:LoginView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HomePageViewModel}">
            <view:HomePage/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:Dashboard1ViewModel}">
                <view:Dashbaord1/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:EnergyMonitorViewModel}">
                <view:EnergyMonitorView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:EnergyMonitorViewModel2}">
                <view:EnergyMonitor2/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ConfigurationViewModel}">
                <view:MeterConfigView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:Iec61850MonitorViewModel}">
                <view:Iec61850MonitorView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:MqttMonitorViewModel}">
                <view:MqttMonitorView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:IecConfigViewModel}">
                <view:IecConfigView/>
            </DataTemplate>


            <DataTemplate DataType="{x:Type vm:ReportViewerViewModel}">
                <view:ReportViewerView/>
            </DataTemplate>

        </ResourceDictionary>

    </Application.Resources>
</Application>
