<UserControl x:Class="IECGUI.Controls.AnalogGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.Controls"
             mc:Ignorable="d" 
             d:DesignWidth="250">
    <Grid>

        <!-- Gauge Zones -->
        <Path Stroke="LimeGreen"
              StrokeThickness="20"
              Data="M 40,140 A 80,80 0 0 1 80,70"/>

        <Path Stroke="Orange"
              StrokeThickness="20"
              Data="M 80,70 A 80,80 0 0 1 170,70"/>

        <Path Stroke="Red"
              StrokeThickness="20"
              Data="M 170,70 A 80,80 0 0 1 210,140"/>

        <!-- Needle -->
        <Line x:Name="Needle"
              X1="125"
              Y1="140"
              X2="125"
              Y2="70"
              Stroke="Silver"
              StrokeThickness="5"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Triangle">

            <Line.RenderTransform>
                <RotateTransform x:Name="NeedleRotate"
                                 CenterX="125"
                                 CenterY="140"/>
            </Line.RenderTransform>

        </Line>

        <!-- Needle Center -->
        <Ellipse Width="9"
                 Height="9"
                 Fill="Black"
                 Stroke="White"
                 StrokeThickness="2"
                 HorizontalAlignment="Center"
                 
                 Margin="0,100,0,0"/>

        <!-- Value -->
        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                 Path=Value,
                                 StringFormat={}{0:F1}}"
                   Foreground="White"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,85,0,0"/>

        <!-- Unit -->
        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                 Path=Unit}"
                   Foreground="White"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Margin="0,120,0,0"/>

        <!-- Title -->
        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                 Path=Title}"
                   Foreground="White"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,5"/>

    </Grid>
</UserControl>
