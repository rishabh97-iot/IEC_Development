<UserControl x:Class="IECGUI.Controls.TriangleIndicator"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100">
    <Grid Background="Transparent">

        <Polygon x:Name="PART_Triangle"
               
                 Fill="{Binding Fill, ElementName=root}"
                 Stroke="{Binding Stroke, ElementName=root}"
                 StrokeThickness="{Binding StrokeThickness, ElementName=root}"/>


    </Grid>
</UserControl>
