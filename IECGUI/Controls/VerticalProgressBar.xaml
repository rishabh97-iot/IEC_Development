<UserControl x:Class="IECGUI.Controls.VerticalProgressBar"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="80">
    <Grid Width="20"
      Height="200" Background="Transparent">

        <!-- Background -->
        <Border Background="#606060"/>

        <!-- Green Fill -->
        <Border x:Name="FillBorder"
            Background="LimeGreen"
            VerticalAlignment="Top"                
            Height="{Binding FillHeight ,ElementName=root}"/>

    </Grid>
</UserControl>
