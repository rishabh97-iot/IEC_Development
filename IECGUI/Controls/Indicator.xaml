<UserControl x:Class="IECGUI.Controls.Indicator"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100">


    <StackPanel HorizontalAlignment="Center">

        <Grid Width="{Binding LampSize, ElementName=root}"
              Height="{Binding LampSize, ElementName=root}">

            <!-- Outer Ring -->
            <Ellipse
                Stroke="#444"
                StrokeThickness="0">

                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#505050" Offset="0"/>
                        <GradientStop Color="#1E1E1E" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>

            </Ellipse>

            <!-- Lamp -->
            <Ellipse Margin="6">

                <Ellipse.Style>

                    <Style TargetType="Ellipse">

                        <Setter Property="Fill">
                            <Setter.Value>

                                <RadialGradientBrush>
                                    <GradientStop Color="#303030" Offset="0"/>
                                    <GradientStop Color="#151515" Offset="1"/>
                                </RadialGradientBrush>

                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsOn,ElementName=root}"
                                         Value="True">

                                <Setter Property="Fill">

                                    <Setter.Value>

                                        <RadialGradientBrush>

                                            <GradientStop Offset="0"
                                                Color="White"/>

                                            <GradientStop Offset="0.4"
                                                Color="{Binding LampColor,ElementName=root}"/>

                                            <GradientStop Offset="1"
                                                Color="{Binding LampColor,ElementName=root}"/>

                                        </RadialGradientBrush>

                                    </Setter.Value>

                                </Setter>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Ellipse.Style>

            </Ellipse>

            <!--Ellipse Gloss -->
            <Ellipse Margin="10,8,10,28"
                     IsHitTestVisible="False">

                <Ellipse.Fill>

                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#AAFFFFFF"
                                      Offset="0"/>

                        <GradientStop Color="#00FFFFFF"
                                      Offset="1"/>

                    </LinearGradientBrush>

                </Ellipse.Fill>

            </Ellipse>

        </Grid>

        <TextBlock
            Margin="0,5,0,0"
            HorizontalAlignment="Center"
            Text="{Binding Label,ElementName=root}"
            Foreground="White"
            FontSize="12"/>

    </StackPanel>

</UserControl>
