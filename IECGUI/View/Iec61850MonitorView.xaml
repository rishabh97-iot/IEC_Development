<UserControl x:Class="IECGUI.View.Iec61850MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:IECGUI.Converters"
             Background="#1E1E2E" 
             Height="930" Width="1920">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- Header -->
            <RowDefinition Height="40"/>
            <!-- Status Bar -->
            <RowDefinition Height="220"/>
            <!-- DataGrid — all relays -->
            <RowDefinition Height="620"/>
            <!-- Detail panel — selected relay -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0">
            <Button Content="◄ Back"
                    Command="{Binding BackCommand}"
                    Width="100" Height="35"
                    DockPanel.Dock="Left"
                    Foreground="White" Background="#3D5A80"/>
            <Button Content="⚙ Configuration"
                    Command="{Binding ConfigurationCommand}"
                    Width="130" Height="35"
                    DockPanel.Dock="Left" Margin="10,0,0,0"
                    Foreground="White" Background="#8E44AD"/>
            <TextBlock Text="IEC 61850 — Protection Relay Monitor"
                       Foreground="White" FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </DockPanel>

        <!-- Status Bar -->
        <Border Grid.Row="1" CornerRadius="5" Margin="0,5"
                Background="{Binding IsOnline,
                    Converter={StaticResource BoolToColorConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White" FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- All Relays DataGrid -->
        <Border Grid.Row="2" Background="#2A2A3E"
                CornerRadius="8" Margin="0,5,0,5" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Connected Relays — Click a row to see details"
                           Foreground="#00D4FF"
                           FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="5,0"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding RelayReadings}"
                          SelectedItem="{Binding SelectedRelay, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          Background="Transparent"
                          Foreground="White"
                          RowBackground="#2A2A3E"
                          AlternatingRowBackground="#323250"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          FontSize="13">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#3D5A80"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- Status indicator -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                    <Setter Property="Foreground" Value="#888888"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>

                        <!-- Status dot -->
                        <DataGridTemplateColumn Header="Status" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12" Height="12"
                                             HorizontalAlignment="Center"
                                             Fill="{Binding IsOnline,
                                                 Converter={StaticResource BoolToColorConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Relay Name" Width="160"
                            Binding="{Binding RelayName}"/>

                        <DataGridTextColumn Header="Hz" Width="75"
                            Binding="{Binding Hz, StringFormat='{}{0:F2}'}"/>

                        <DataGridTextColumn Header="V Ph-A (V)" Width="95"
                            Binding="{Binding PhV_A, StringFormat='{}{0:F2}'}"/>

                        <DataGridTextColumn Header="V Ph-B (V)" Width="95"
                            Binding="{Binding PhV_B, StringFormat='{}{0:F2}'}"/>

                        <DataGridTextColumn Header="V Ph-C (V)" Width="95"
                            Binding="{Binding PhV_C, StringFormat='{}{0:F2}'}"/>

                        <DataGridTextColumn Header="I Ph-A (A)" Width="90"
                            Binding="{Binding A_PhsA, StringFormat='{}{0:F3}'}"/>

                        <DataGridTextColumn Header="I Ph-B (A)" Width="90"
                            Binding="{Binding A_PhsB, StringFormat='{}{0:F3}'}"/>

                        <DataGridTextColumn Header="I Ph-C (A)" Width="90"
                            Binding="{Binding A_PhsC, StringFormat='{}{0:F3}'}"/>

                        <DataGridTextColumn Header="kW" Width="75"
                            Binding="{Binding TotW, StringFormat='{}{0:F2}'}"/>

                        <DataGridTextColumn Header="kVAr" Width="75"
                            Binding="{Binding TotVAr, StringFormat='{}{0:F2}'}"/>

                        <DataGridTextColumn Header="PF" Width="65"
                            Binding="{Binding TotPF, StringFormat='{}{0:F3}'}"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Selected Relay Detail Panel -->
        <Grid Grid.Row="3" DataContext="{Binding SelectedRelay}"
              Margin="0,5,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Voltage -->
            <Border Grid.Column="0" Background="#2A2A3E"
                    CornerRadius="10" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Foreground="#00D4FF"
                               FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,10">
                        <Run Text="⚡ VOLTAGE — "/>
                        <Run Text="{Binding RelayName}"/>
                    </TextBlock>

                    <TextBlock Text="Phase to Neutral (V)"
                               Foreground="Gray" FontSize="12"/>
                    <Separator Background="#3A3A5E" Margin="0,5"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ph-A"
                                   Foreground="#FF6B6B" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding PhV_A, StringFormat='{}{0:F2} V'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ph-B"
                                   Foreground="#FFE66D" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding PhV_B, StringFormat='{}{0:F2} V'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ph-C"
                                   Foreground="#4ECDC4" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding PhV_C, StringFormat='{}{0:F2} V'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Grid>

                    <TextBlock Text="Line to Line (V)"
                               Foreground="Gray" FontSize="12"
                               Margin="0,12,0,0"/>
                    <Separator Background="#3A3A5E" Margin="0,5"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AB"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding PPV_AB, StringFormat='{}{0:F2} V'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="BC"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding PPV_BC, StringFormat='{}{0:F2} V'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="CA"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding PPV_CA, StringFormat='{}{0:F2} V'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Column 2: Current + Frequency -->
            <Border Grid.Column="1" Background="#2A2A3E"
                    CornerRadius="10" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="⚡ CURRENT &amp; FREQUENCY"
                               Foreground="#FFE66D"
                               FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Current (A)"
                               Foreground="Gray" FontSize="12"/>
                    <Separator Background="#3A3A5E" Margin="0,5"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ph-A"
                                   Foreground="#FF6B6B" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding A_PhsA, StringFormat='{}{0:F3} A'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ph-B"
                                   Foreground="#FFE66D" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding A_PhsB, StringFormat='{}{0:F3} A'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ph-C"
                                   Foreground="#4ECDC4" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding A_PhsC, StringFormat='{}{0:F3} A'}"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Grid>

                    <TextBlock Text="Frequency"
                               Foreground="Gray" FontSize="12"
                               Margin="0,15,0,0"/>
                    <Separator Background="#3A3A5E" Margin="0,5"/>

                    <TextBlock Text="{Binding Hz, StringFormat='{}{0:F2} Hz'}"
                               Foreground="#00FF88"
                               FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,10"/>
                </StackPanel>
            </Border>

            <!-- Column 3: Power -->
            <Border Grid.Column="2" Background="#2A2A3E"
                    CornerRadius="10" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="⚡ POWER"
                               Foreground="#FF6B6B"
                               FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <Separator Background="#3A3A5E" Margin="0,5"/>

                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="55"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="45"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Active"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding TotW, StringFormat='{}{0:F2}'}"
                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="kW"
                                   Foreground="Gray" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Apparent"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding TotVA, StringFormat='{}{0:F2}'}"
                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="kVA"
                                   Foreground="Gray" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Reactive"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding TotVAr, StringFormat='{}{0:F2}'}"
                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="kVAr"
                                   Foreground="Gray" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Power Factor"
                                   Foreground="Silver" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding TotPF, StringFormat='{}{0:F3}'}"
                                   Foreground="#00D4FF" FontSize="22" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>