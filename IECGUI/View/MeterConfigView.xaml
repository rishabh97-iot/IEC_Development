<UserControl x:Class="IECGUI.View.MeterConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.View"
             xmlns:conv="clr-namespace:IECGUI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="930" d:DesignWidth="1920">
    <UserControl.Resources>
        <conv:ProtocolToVisibilityConverter x:Key="IsTcp" TargetProtocol="ModbusTcp"/>
        <conv:ProtocolToVisibilityConverter x:Key="IsRtu" TargetProtocol="ModbusRtu"/>
    </UserControl.Resources>
    <Grid Margin="5" Background="White" Height="930" Width="1920">




        <TabControl Background="Transparent">
            <TabControl.Resources>

                <!-- SCADA Tab Style -->
                <Style TargetType="TabItem">

                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#0F5BC4"/>
                    <Setter Property="BorderBrush" Value="#3D7EFF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="FontSize" Value="24"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="20,8"/>

                    <Setter Property="Template">

                        <Setter.Value>

                            <ControlTemplate TargetType="TabItem">

                                <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0"
                                Margin="2,2,2,0">

                                    <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                Margin="10,4"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#0078D7"/>
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#1C4DA1"/>
                                    </Trigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#2A6BD8"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>

                        </Setter.Value>

                    </Setter>

                </Style>

            </TabControl.Resources>            

            <!-- Meter List Tab-->
            <TabItem Header="Meter List" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Back to Main Menu" Command="{Binding MenuCommand}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="Gray"  Grid.Row="1" Grid.Column="0"
                                BorderThickness="1" Height="450" Width="250"
                                Margin="5" HorizontalAlignment="Right">

                            <DockPanel Grid.Row="1">

                                <Button DockPanel.Dock="Bottom" FontSize="20"
                                Content="Delete Meter"
                                Height="35"
                                Margin="5"
                                Command="{Binding DeleteMeterCommand}"/>

                                <Button DockPanel.Dock="Bottom" FontSize="20"
                                Content="Add Meter"
                                Height="35"
                                Margin="5"
                                Command="{Binding AddMeterCommand}"/>



                                <ListBox ItemsSource="{Binding Meters}"
                                 SelectedItem="{Binding SelectedMeter}">

                                    <ListBox.ItemTemplate>

                                        <DataTemplate>

                                            <TextBlock Text="{Binding MeterName}"
                                               FontSize="20"/>

                                        </DataTemplate>

                                    </ListBox.ItemTemplate>

                                </ListBox>

                            </DockPanel>

                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Height="450" Width="250" HorizontalAlignment="Left" Margin="5"  BorderBrush="Black"  BorderThickness="2"  Padding="5">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0"> 
                                    <TextBlock Text="Protocol" VerticalAlignment="Center" FontSize="20" Margin="0,0,8,0" Foreground="Black"/>
                                    <ComboBox Width="160" Height="35" FontSize="18"
                                              ItemsSource="{Binding Protocols}"
                                              SelectedItem="{Binding SelectedMeter.Communication.Protocol, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Text="Meter Name" Margin="0,5,0,0" FontSize="20" Foreground="Black"/>
                                <TextBox Text="{Binding SelectedMeter.MeterName}" Margin="0,10,0,0" FontSize="20"/>
                                <StackPanel Visibility="{Binding SelectedMeter.Communication.Protocol, Converter={StaticResource IsRtu}}">

                                    <TextBlock Margin="0,5,0,0" Text="COM Port" FontSize="20" Foreground="Black"/>

                                    <!-- Changed: COM port selection via ComboBox bound to available ports -->
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <ComboBox Width="200" Height="35"
                                            IsEditable="True"
                                            ItemsSource="{Binding AvailableComPorts}"
                                            SelectedItem="{Binding SelectedMeter.Communication.ComPort, Mode=TwoWay}"
                                            FontSize="20"/>
                                        <Button Content="🔄" Margin="1,0,0,0" Padding="0,0"
                                            Command="{Binding RefreshComPortsCommand}" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Margin="0,10,0,0" Text="Baud Rate" FontSize="20" Foreground="Black"/>

                                    <!-- In the meter details panel, change Baud Rate and Slave ID textboxes to ComboBoxes -->
                                    <ComboBox ItemsSource="{Binding DataContext.BaudRates, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding SelectedMeter.Communication.BaudRate, Mode=TwoWay}"
                                          Margin="0,10,0,0" FontSize="20" HorizontalContentAlignment="Center" />



                                </StackPanel>
                                <!-- TCP specific: IP + Port fields -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                            Visibility="{Binding SelectedMeter.Communication.Protocol, Converter={StaticResource IsTcp}}">
                                    <TextBlock Text="IP" FontSize="20" VerticalAlignment="Center" Margin="0,0,0,0" Foreground="Black"/>
                                    <TextBox Text="{Binding SelectedMeter.Communication.IpAddress, Mode=TwoWay}" Width="120" FontSize="18" />
                                    <TextBlock Text="Port" FontSize="20" VerticalAlignment="Center" Margin="0,0,0,0" Foreground="Black"/>
                                    <TextBox Text="{Binding SelectedMeter.Communication.TcpPort, Mode=TwoWay}" Width="60" FontSize="18" />
                                </StackPanel>

                                <TextBlock Margin="0,10,0,0" Text="Slave ID" FontSize="20" Foreground="Black"/>
                                <ComboBox ItemsSource="{Binding DataContext.SlaveIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding SelectedMeter.Communication.SlaveId, Mode=TwoWay}"
                                          Margin="0,10,0,0" FontSize="20" HorizontalContentAlignment="Center" />

                                <Button Margin="0,10,0,0"  Height="40"   Content="Save Configuration" Command="{Binding SaveCommand}" FontSize="20"/>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                </TabItem>

            <!-- Comm Config Tab--><!--
            <TabItem Header="Comm Params" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Back to Main Menu" Command="{Binding MenuCommand}"/>
                   
                </Grid>
            </TabItem>-->
            
            <!-- Regiseters Mapping-->
            <TabItem Header="Register Mapping" Height="44" VerticalAlignment="Bottom">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->

                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding Meters}" DisplayMemberPath="MeterName"
                                 SelectedItem="{Binding SelectedMeter, Mode=TwoWay}" Width="Auto"
                                  Margin="5"/>

                        <Button Content="Add"
                                Width="90"
                                Margin="5"
                                Command="{Binding AddRegisterCommand}"/>

                        <Button Content="Edit"
                                Width="90"
                                Margin="5"
                                Command="{Binding EditRegisterCommand}"/>

                        <Button Content="Delete"
                                Width="90"
                                Margin="5"
                                Command="{Binding DeleteRegisterCommand}"/>

                        <Button Content="Save"
                                Width="90"
                                Margin="5"
                                Command="{Binding SaveRegisterCommand}"/>

                        <Button Content="Load Default"
                                Width="150"
                                Margin="5"/>
                        <Button Content="Main Menu"
                                Width="150"
                                Margin="5" Command="{Binding MenuCommand}"/>

                    </StackPanel>

                    <!-- Register Grid -->

                    <DataGrid Grid.Row="1"
                              Margin="0,10,0,0"

                              ItemsSource="{Binding SelectedMeter.Registers}"

                              SelectedItem="{Binding SelectedRegister}"

                              AutoGenerateColumns="False"

                              CanUserAddRows="False"

                              HeadersVisibility="Column"

                              RowHeight="32"

                              FontSize="16">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Parameter Name"
                                    Width="250"
                                    Binding="{Binding ParameterName}"/>

                            <DataGridTextColumn Header="Register"
                                    Width="120"
                                    Binding="{Binding RegisterAddress}"/>

                            <!-- DataGridComboBoxColumn: ItemsSource already bound to DataGrid.DataContext.DataTypes -->
                            <DataGridComboBoxColumn Header="Data Type"
                                                    Width="130"
                                                    SelectedItemBinding="{Binding DataType, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{Binding DataContext.DataTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                            <DataGridTextColumn Header="Unit"
                                                Width="70"
                                                Binding="{Binding Unit}"/>

                            <DataGridTextColumn Header="Scale"
                                                Width="90"
                                                Binding="{Binding ScaleFactor}"/>

                            <DataGridTextColumn Header="Length"
                                                Width="80"
                                                Binding="{Binding Length}"/>

                            <DataGridCheckBoxColumn Header="Enabled"
                                                    Width="80"
                                                    Binding="{Binding IsEnabled}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
