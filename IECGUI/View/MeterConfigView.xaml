<UserControl x:Class="IECGUI.View.MeterConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.View"
             xmlns:conv="clr-namespace:IECGUI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="930" d:DesignWidth="1920">
    <UserControl.Resources>
        <conv:ProtocolToVisibilityConverter x:Key="IsTcp" TargetProtocol="ModbusTcp"/>
        <conv:ProtocolToVisibilityConverter x:Key="IsRtu" TargetProtocol="ModbusRtu"/>
        <Style x:Key="GlassCardButton" TargetType="Button">

            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#55FFFFFF"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="GlassBorder"
                 CornerRadius="15"
                 BorderBrush="#80FFFFFF"
                 BorderThickness="1"
                 Background="{TemplateBinding Background}">

                            <Border.Effect>

                                <DropShadowEffect BlurRadius="25"
                                   ShadowDepth="4"
                                   Opacity="0.35"/>

                            </Border.Effect>

                            <Grid>

                                <!-- Top Glass Reflection -->

                                <Border Height="45"
                         VerticalAlignment="Top"
                         Margin="8"
                         CornerRadius="20"
                         Opacity="0.35">

                                    <Border.Background>

                                        <LinearGradientBrush StartPoint="0,0"
                                              EndPoint="0,1">

                                            <GradientStop Color="White"
                                           Offset="0"/>

                                            <GradientStop Color="#00FFFFFF"
                                           Offset="1"/>

                                        </LinearGradientBrush>

                                    </Border.Background>

                                </Border>

                                <!-- Content -->

                                <ContentPresenter
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Mouse Over -->

                            <Trigger Property="IsMouseOver"
                      Value="True">

                                <Setter TargetName="GlassBorder"
                         Property="Background"
                         Value="#77FFFFFF"/>

                                <Setter TargetName="GlassBorder"
                         Property="BorderBrush"
                         Value="#FFFFFFFF"/>

                            </Trigger>

                            <!-- Click -->

                            <Trigger Property="IsPressed"
                      Value="True">

                                <Setter TargetName="GlassBorder"
                         Property="RenderTransform">

                                    <Setter.Value>

                                        <ScaleTransform ScaleX="0.97"
                                         ScaleY="0.97"/>

                                    </Setter.Value>

                                </Setter>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>
    </UserControl.Resources>


    <Grid Margin="0">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#27283D" Offset="0"/>
                <GradientStop Color="#222334" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="850"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Border Height="70">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#9B3DFF"/>
                        <GradientStop Color="#FF5EB8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <TextBlock
                    Text="Meter Configuration"
                    FontSize="34"
                    FontWeight="Bold"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

        </Grid>




        <TabControl Grid.Row="1" Background="Transparent">
            <TabControl.Resources>

                <!-- SCADA Tab Style -->
                <Style TargetType="TabItem">

                    <Setter Property="Background" Value="#2E3656"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#4A5A88"/>
                    <Setter Property="FontSize" Value="20"/>
                    <Setter Property="Padding" Value="20,8"/>

                    <Setter Property="Template">

                        <Setter.Value>

                            <ControlTemplate TargetType="TabItem">

                                <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0"
                                Margin="2,2,2,0">

                                    <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                Margin="10,4"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#0078D7"/>
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#3B7CFF"/>
                                    </Trigger>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#5A95FF"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>

                        </Setter.Value>

                    </Setter>

                </Style>

            </TabControl.Resources>            

            <!-- Meter List Tab-->
            <TabItem Header="Meter List" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="🏠 Main Menu" Style="{StaticResource GlassCardButton}" Height="50" Width="430" Command="{Binding MenuCommand}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border     Background="#31344B"   BorderBrush="#505A85" CornerRadius="12"    Padding="15"  Grid.Row="1" Grid.Column="0"
                                BorderThickness="1" Height="700" Width="320"
                                Margin="5" HorizontalAlignment="Right">

                            <DockPanel Grid.Row="1">

                                <Button DockPanel.Dock="Bottom" FontSize="20" Style="{StaticResource GlassCardButton}"
                                Content="🗑 Delete Meter"
                                Height="35"
                                Margin="5"
                                Command="{Binding DeleteMeterCommand}"/>

                                <Button DockPanel.Dock="Bottom" FontSize="20" Style="{StaticResource GlassCardButton}"
                                Content="➕ Add Meter"
                                Height="35"
                                Margin="5"
                                Command="{Binding AddMeterCommand}"/>



                                <ListBox ItemsSource="{Binding Meters}" Background="#40456B" BorderThickness="0" Foreground="White"
                                 SelectedItem="{Binding SelectedMeter}">

                                    <ListBox.ItemTemplate>

                                        <DataTemplate>

                                            <TextBlock Text="{Binding MeterName}"
                                               FontSize="20"/>

                                        </DataTemplate>

                                    </ListBox.ItemTemplate>

                                </ListBox>

                            </DockPanel>

                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Height="700" Width="320" HorizontalAlignment="Left" Margin="5"   Background="#31344B"   BorderBrush="#505A85" CornerRadius="12"  BorderThickness="2"  Padding="5">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0"> 
                                    <TextBlock Text="Protocol" VerticalAlignment="Center" FontSize="20" Margin="0,0,8,0" Foreground="White"/>
                                    <ComboBox Width="160" Height="35" FontSize="18" Background="#40456B" Foreground="Black" BorderBrush="#6A7AB5"
                                              ItemsSource="{Binding Protocols}"
                                              SelectedItem="{Binding SelectedMeter.Communication.Protocol, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Text="Meter Name" Margin="0,5,0,0" FontSize="20" Foreground="White"/>
                                <TextBox Text="{Binding SelectedMeter.MeterName}" Margin="0,10,0,0" FontSize="20"/>
                                <StackPanel Visibility="{Binding SelectedMeter.Communication.Protocol, Converter={StaticResource IsRtu}}">

                                    <TextBlock Margin="0,5,0,0" Text="COM Port" FontSize="20" Foreground="White"/>

                                    <!-- Changed: COM port selection via ComboBox bound to available ports -->
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <ComboBox Width="200" Height="35" Background="#40456B" Foreground="Black" BorderBrush="#6A7AB5"
                                            IsEditable="True"
                                            ItemsSource="{Binding AvailableComPorts}"
                                            SelectedItem="{Binding SelectedMeter.Communication.ComPort, Mode=TwoWay}"
                                            FontSize="20"/>
                                        <Button Content="🔄" Margin="1,0,0,0" Padding="0,0"
                                            Command="{Binding RefreshComPortsCommand}" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Margin="0,10,0,0" Text="Baud Rate" FontSize="20" Foreground="White"/>

                                    <!-- In the meter details panel, change Baud Rate and Slave ID textboxes to ComboBoxes -->
                                    <ComboBox ItemsSource="{Binding DataContext.BaudRates, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding SelectedMeter.Communication.BaudRate, Mode=TwoWay}"
                                          Margin="0,10,0,0" FontSize="20" HorizontalContentAlignment="Center" />



                                </StackPanel>
                                <!-- TCP specific: IP + Port fields -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                            Visibility="{Binding SelectedMeter.Communication.Protocol, Converter={StaticResource IsTcp}}">
                                    <TextBlock Text="IP" FontSize="20" VerticalAlignment="Center" Margin="0,0,0,0" Foreground="White"/>
                                    <TextBox Text="{Binding SelectedMeter.Communication.IpAddress, Mode=TwoWay}" Width="120" FontSize="18" />
                                    <TextBlock Text="Port" FontSize="20" VerticalAlignment="Center" Margin="0,0,0,0" Foreground="White"/>
                                    <TextBox Text="{Binding SelectedMeter.Communication.TcpPort, Mode=TwoWay}" Width="60" FontSize="18" />
                                </StackPanel>

                                <TextBlock Margin="0,10,0,0" Text="Slave ID" FontSize="20" Foreground="White"/>
                                <ComboBox ItemsSource="{Binding DataContext.SlaveIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding SelectedMeter.Communication.SlaveId, Mode=TwoWay}"
                                          Margin="0,10,0,0" FontSize="20" HorizontalContentAlignment="Center" Background="#40456B" Foreground="Black" BorderBrush="#6A7AB5"/>

                                <Button Margin="0,10,0,0"  Height="60" Width="250"  Style="{StaticResource GlassCardButton}"  Content="💾 Save Configuration" Command="{Binding SaveCommand}" FontSize="20"/>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                </TabItem>

            <!-- Comm Config Tab--><!--
            <TabItem Header="Comm Params" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Back to Main Menu" Command="{Binding MenuCommand}"/>
                   
                </Grid>
            </TabItem>-->
            
            <!-- Regiseters Mapping-->
            <TabItem Header="Register Mapping" Height="44" VerticalAlignment="Bottom">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->

                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding Meters}" DisplayMemberPath="MeterName"
                                 SelectedItem="{Binding SelectedMeter, Mode=TwoWay}" Width="Auto"
                                  Margin="5"/>

                        <Button Content="Add"
                                Width="90"
                                Margin="5"
                                Command="{Binding AddRegisterCommand}"/>

                        <Button Content="Edit"
                                Width="90"
                                Margin="5"
                                Command="{Binding EditRegisterCommand}"/>

                        <Button Content="Delete"
                                Width="90"
                                Margin="5"
                                Command="{Binding DeleteRegisterCommand}"/>

                        <Button Content="Save"
                                Width="90"
                                Margin="5"
                                Command="{Binding SaveRegisterCommand}"/>

                        <Button Content="Load Default"
                                Width="150"
                                Margin="5"/>
                        <Button Content="Main Menu"
                                Width="150"
                                Margin="5" Command="{Binding MenuCommand}"/>

                    </StackPanel>

                    <!-- Register Grid -->

                    <DataGrid Grid.Row="1"
                              Margin="0,10,0,0"

                              ItemsSource="{Binding SelectedMeter.Registers}"

                              SelectedItem="{Binding SelectedRegister}"

                              AutoGenerateColumns="False"

                              CanUserAddRows="False"

                              HeadersVisibility="Column"

                              RowHeight="32"
                              Background="#31344B"

                            Foreground="White"

                            RowBackground="#31344B"

                            AlternatingRowBackground="#383D58"

                            GridLinesVisibility="None"

                            BorderThickness="0"                          

                              FontSize="16">

                        <DataGrid.ColumnHeaderStyle>

                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Background" Value="#3A4670"/>

                                <Setter Property="Foreground" Value="White"/>

                                <Setter Property="FontWeight" Value="Bold"/>

                                <Setter Property="Height" Value="40"/>

                            </Style>

                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Parameter Name"
                                    Width="250"
                                    Binding="{Binding ParameterName}"/>

                            <DataGridTextColumn Header="Register"
                                    Width="120"
                                    Binding="{Binding RegisterAddress}"/>

                            <!-- DataGridComboBoxColumn: ItemsSource already bound to DataGrid.DataContext.DataTypes -->
                            <DataGridComboBoxColumn Header="Data Type"
                                                    Width="130"
                                                    SelectedItemBinding="{Binding DataType, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{Binding DataContext.DataTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                            <DataGridTextColumn Header="Unit"
                                                Width="70"
                                                Binding="{Binding Unit}"/>

                            <DataGridTextColumn Header="Scale"
                                                Width="90"
                                                Binding="{Binding ScaleFactor}"/>

                            <DataGridTextColumn Header="Length"
                                                Width="80"
                                                Binding="{Binding Length}"/>

                            <DataGridCheckBoxColumn Header="Enabled"
                                                    Width="80"
                                                    Binding="{Binding IsEnabled}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
