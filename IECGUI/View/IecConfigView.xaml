<!-- IECGUI/View/IecConfigView.xaml -->
<UserControl x:Class="IECGUI.View.IecConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:IEC.Shared.IECModels;assembly=IEC.Shared"
             Background="#1E1E2E"
             Height="930" Width="1920">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="850"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0">
            <Button Content="◄ Back"
                    Command="{Binding BackCommand}" Style="{StaticResource GlassButton}"
                    Width="100" Height="35"
                    DockPanel.Dock="Left"
                    Foreground="White" Background="#3D5A80"/>
            <Button Content="💾 Save All"
                    Command="{Binding SaveCommand}" Style="{StaticResource GlassButton.Green}"
                    Width="120" Height="35"
                    DockPanel.Dock="Right"
                    Foreground="White" Background="#27AE60"/>
            <TextBlock Text="IEC 61850 — Configuration"
                       Foreground="White" FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </DockPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="Transparent"
                    Margin="0,10,0,0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="20,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="#1C4DA1"
                                        CornerRadius="5,5,0,0"
                                        Margin="2,2,2,0"
                                        Padding="15,6">
                                    <ContentPresenter
                                        ContentSource="Header"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border"
                                                Property="Background"
                                                Value="#0078D7"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border"
                                                Property="Background"
                                                Value="#2A6BD8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ═══════════════════════════════════════════ -->
            <!-- TAB 1: Relay List                          -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="Relay List">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Relay List Panel -->
                    <Border Grid.Column="0"
                            Background="#2A2A3E"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,10,0">
                        <DockPanel>
                            <!-- Buttons -->
                            <StackPanel DockPanel.Dock="Bottom"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0">
                                <Button Content="+ Add"
                                        Command="{Binding AddRelayCommand}" Style="{StaticResource GlassButton}"
                                        Width="90" Height="32"
                                        Margin="0,0,5,0"
                                        Foreground="White"
                                        Background="#27AE60"/>
                                <Button Content="Delete"
                                        Command="{Binding DeleteRelayCommand}" Style="{StaticResource GlassButton}"
                                        Width="90" Height="32"
                                        Foreground="White"
                                        Background="#C0392B"/>
                            </StackPanel>

                            <TextBlock DockPanel.Dock="Top"
                                       Text="Configured Relays"
                                       Foreground="#00D4FF"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <ListBox ItemsSource="{Binding Relays}"
                                     SelectedItem="{Binding SelectedRelay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,3">
                                            <TextBlock Text="{Binding RelayName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="Gray">
                                                <Run Text="{Binding IPAddress}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Port}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Relay Detail Panel -->
                    <Border Grid.Column="1"
                            Background="#2A2A3E"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Relay Details"
                                       Foreground="#00D4FF"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <!-- Relay Name -->
                            <TextBlock Text="Relay Name"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedRelay.RelayName,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3A3A5E"
                                     Foreground="White"
                                     BorderBrush="#5A5A8E"
                                     Padding="8,5"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <!-- IP Address -->
                            <TextBlock Text="IP Address"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedRelay.IPAddress,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3A3A5E"
                                     Foreground="White"
                                     BorderBrush="#5A5A8E"
                                     Padding="8,5"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <!-- Port -->
                            <TextBlock Text="Port"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedRelay.Port,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3A3A5E"
                                     Foreground="White"
                                     BorderBrush="#5A5A8E"
                                     Padding="8,5"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <!-- Poll Interval -->
                            <TextBlock Text="Poll Interval (ms)"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedRelay.PollIntervalMs,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3A3A5E"
                                     Foreground="White"
                                     BorderBrush="#5A5A8E"
                                     Padding="8,5"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <!-- Enabled Toggle -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,5,0,0">
                                <CheckBox IsChecked="{Binding SelectedRelay.IsEnabled}"
                                          Foreground="White"
                                          FontSize="14"
                                          Content="Relay Enabled"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- TAB 2: Logical Node Config                 -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="Logical Node">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LN List -->
                    <Border Grid.Column="0"
                            Background="#2A2A3E"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,10,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0">
                                <Button Content="+ Add"
                                        Command="{Binding AddLnCommand}" Style="{StaticResource GlassButton}"
                                        Width="90" Height="32"
                                        Margin="0,0,5,0"
                                        Foreground="White"
                                        Background="#27AE60"/>
                                <Button Content="Delete"
                                        Command="{Binding DeleteLnCommand}" Style="{StaticResource GlassButton}"
                                        Width="90" Height="32"
                                        Foreground="White"
                                        Background="#C0392B"/>
                            </StackPanel>

                            <!-- Relay Selector -->
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Select Relay"
                                       Foreground="Gray"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <ComboBox DockPanel.Dock="Top"
                                      ItemsSource="{Binding Relays}" 
                                      SelectedItem="{Binding SelectedRelay}"
                                      DisplayMemberPath="RelayName"
                                      Margin="0,0,0,10"
                                      Foreground="Black"
                                      Background="#3A3A5E"/>

                            <TextBlock DockPanel.Dock="Top"
                                       Text="Logical Nodes"
                                       Foreground="#00D4FF"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <ListBox ItemsSource="{Binding LogicalNodes}"
                                     SelectedItem="{Binding SelectedLn}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,3">
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="White">
                                                <Run Text="{Binding LogicalDevice}"/>
                                                <Run Text="/" Foreground="Gray"/>
                                                <Run Text="{Binding LogicalNode}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding FC}"
                                                       FontSize="11"
                                                       Foreground="#FFE66D"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- LN Detail -->
                    <Border Grid.Column="1"
                            Background="#2A2A3E"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Logical Node Details"
                                       Foreground="#00D4FF"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <TextBlock Text="Logical Device"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedLn.LogicalDevice,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3A3A5E" Foreground="White"
                                     BorderBrush="#5A5A8E" Padding="8,5"
                                     FontSize="14" Margin="0,0,0,12"/>

                            <TextBlock Text="Logical Node"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedLn.LogicalNode,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3A3A5E" Foreground="White"
                                     BorderBrush="#5A5A8E" Padding="8,5"
                                     FontSize="14" Margin="0,0,0,12"/>

                            <TextBlock Text="Functional Constraint (FC)"
                                       Foreground="Gray" FontSize="12"
                                       Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding FcOptions}"
                                      SelectedItem="{Binding SelectedLn.FC}"
                                      Background="#3A3A5E"
                                      Foreground="Black"
                                      FontSize="14"
                                      Padding="8,5"
                                      Margin="0,0,0,12"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- TAB 3: DO Mapping                          -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="DO Mapping">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="Relay:"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding Relays}"
                                  SelectedItem="{Binding SelectedRelay}"
                                  DisplayMemberPath="RelayName"
                                  Width="150" Margin="0,0,15,0"
                                  Background="#3A3A5E" Foreground="Black"/>

                        <TextBlock Text="LN:"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding LogicalNodes}"
                                  SelectedItem="{Binding SelectedLn}"
                                  Width="180" Margin="0,0,15,0"
                                  Background="#3A3A5E" Foreground="Black">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="Black">
                                        <Run Text="{Binding LogicalDevice}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding LogicalNode}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Content="+ Add"
                                Command="{Binding AddMappingCommand}" Style="{StaticResource GlassButton}"
                                Width="80" Height="32"
                                Margin="0,0,5,0"
                                Foreground="White" Background="#27AE60"/>
                        <Button Content="Delete"
                                Command="{Binding DeleteMappingCommand}" Style="{StaticResource GlassButton}"
                                Width="80" Height="32"
                                Margin="0,0,5,0"
                                Foreground="White" Background="#C0392B"/>
                        <Button Content="Load Defaults"
                                Command="{Binding LoadDefaultMappingsCommand}" Style="{StaticResource GlassButton}"
                                Width="120" Height="32"
                                Foreground="White" Background="#8E44AD"/>
                    </StackPanel>

                    <!-- Mapping DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Mappings}"
                              SelectedItem="{Binding SelectedMapping}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Background="#2A2A3E"
                              Foreground="White"
                              RowBackground="#2A2A3E"
                              AlternatingRowBackground="#323250"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              FontSize="13"
                              Margin="0,5,0,0">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#3D5A80"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridCheckBoxColumn Header="Enabled"
                                                    Width="70"
                                                    Binding="{Binding IsEnabled}"/>

                            <DataGridTextColumn Header="Parameter Name"
                                                Width="160"
                                                Binding="{Binding ParameterName}"/>

                            <DataGridTextColumn Header="DO Index"
                                                Width="85"
                                                Binding="{Binding DOIndex}"/>

                            <DataGridComboBoxColumn Header="Value Type"
                                                    Width="110"
                                                    SelectedItemBinding="{Binding ValueType}"
                                                    ItemsSource="{Binding DataContext.ValueTypeOptions,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                            <DataGridTextColumn Header="Phase Index"
                                                Width="95"
                                                Binding="{Binding PhaseIndex}"/>

                            <DataGridTextColumn Header="Unit"
                                                Width="70"
                                                Binding="{Binding Unit}"/>

                            <DataGridTextColumn Header="Min Value"
                                                Width="85"
                                                Binding="{Binding MinValue}"/>

                            <DataGridTextColumn Header="Max Value"
                                                Width="85"
                                                Binding="{Binding MaxValue}"/>

                            <DataGridTextColumn Header="Alarm Low"
                                                Width="90"
                                                Binding="{Binding AlarmLow}"/>

                            <DataGridTextColumn Header="Alarm High"
                                                Width="90"
                                                Binding="{Binding AlarmHigh}"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>