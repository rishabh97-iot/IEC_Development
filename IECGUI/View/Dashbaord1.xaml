<UserControl x:Class="IECGUI.View.Dashbaord1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.View"
             xmlns:controls ="clr-namespace:IECGUI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="930" d:DesignWidth="1920">
    <UserControl.Resources>
        <Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>

        </Style>
    </UserControl.Resources>

    <Grid Background="CadetBlue">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="720"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#2A346A">

            <DockPanel>

                <TextBlock Text="Grid SubStation-031"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="20,0"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <!--<Button Content="Energy Monitor" Width="100" Command="{Binding HomeCommand}"/>
                    <Button Content="Gauge View" Width="100" Command="{Binding AlarmCommand}"/>
                    <Button Content="Relay Status" Width="100"  Command="{Binding EventsCommand}"/>
                    <Button Content="Meter Config" Width="100" Command="{Binding TrendingCommand}"/>-->
                    <Button Content="Menu" Margin="1550,0,0,0" Width="100" Command="{Binding MenuCommand}"/>
                </StackPanel>

            </DockPanel>

        </Border>

        <!-- Generator Summary -->
        <UniformGrid Grid.Row="1"
                     Columns="5"                    
                     Margin="10">

            <GroupBox Header="G1" >
                <StackPanel >
                    <TextBlock Text="Load : 3.9 MW" Style="{StaticResource ColumnHeaderStyle}" />
                    <TextBlock Text="Frequency : 49.5 Hz" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Voltage : 10.5 MV" Style="{StaticResource ColumnHeaderStyle}" />
                </StackPanel>
            </GroupBox>
            <GroupBox Header="G2" >
                <StackPanel>
                    <TextBlock Text="Load : 3.9 MW" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Frequency : 49.5 Hz" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Voltage : 10.5 MV" Style="{StaticResource ColumnHeaderStyle}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="G3">
                <StackPanel>
                    <TextBlock Text="Load : 3.9 MW" Foreground="White" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Frequency : 49.5 Hz" Foreground="White" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Voltage : 10.5 MV" Foreground="White" Style="{StaticResource ColumnHeaderStyle}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="G4" >
                <StackPanel>
                    <TextBlock Text="Load : 3.9 MW" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Frequency : 49.5 Hz" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Voltage : 10.5 MV" Style="{StaticResource ColumnHeaderStyle}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="G5" >
                <StackPanel>
                    <TextBlock Text="Load : 3.9 MW" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Frequency : 49.5 Hz" Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Text="Voltage : 10.5 MV" Style="{StaticResource ColumnHeaderStyle}"/>
                </StackPanel>
            </GroupBox>
        </UniformGrid>

