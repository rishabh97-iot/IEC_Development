<UserControl x:Class="IECGUI.View.EnergyMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IECGUI.View"
             mc:Ignorable="d" 
             d:DesignHeight="930" d:DesignWidth="1920">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="840"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#2A2A3E" BorderBrush="AntiqueWhite" BorderThickness="2" Grid.Row="0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Energy Monitoring Dashboard"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Connect" Foreground="White" Width="200" FontSize="20" FontWeight="ExtraBold" Background="LimeGreen" Margin="5" HorizontalAlignment="Center" Style="{StaticResource GlassButton}" Command="{Binding Connect}"/>
                <Button Grid.Column="2" Content="Disconnect" Foreground="White" Width="200" FontSize="20" FontWeight="ExtraBold" Background="Red" Margin="5" HorizontalAlignment="Left" Style="{StaticResource GlassButton}" Command="{Binding Disconnect}"/>
                <Button Grid.Column="3" x:Name="BACK" Content="BACK" Foreground="White" Width="100" HorizontalAlignment="Right" Margin="5,5,5,5" Style="{StaticResource GlassButton.Cyan}" Command="{Binding ReturnToHome}"/>
            </Grid>
        </Border>
        

        <!-- Meter Panels -->
        <ScrollViewer Grid.Row="1" Background="#2A2A3E">

            <ItemsControl ItemsSource="{Binding Meters}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border Margin="8"
                                Width="430"
                                Height="430"
                                Background="#31344B" 
                                BorderBrush="#505A85"
                                CornerRadius="15"
                                BorderThickness="4" >

                            <Grid Margin="10">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!--================ HEADER =================-->

                                <TextBlock Text="{Binding MeterName}"
                                           Grid.Row="0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="Orange"/>
                                <TextBlock Text="{Binding MeterStatus}"
                                         Grid.Row="0"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Top" Foreground="White" Background="Transparent"
                                         FontSize="16"
                                         Width="200"
                                         Margin="0" />

                                <!--================ BODY =================-->

                                <Grid Grid.Row="1">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.8*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                        <RowDefinition Height="28"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1 -->
                                    <TextBlock Text="Voltage A-N" Grid.Row="0" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding VoltageA_N,StringFormat={}{0:F2}}" Grid.Row="0" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="V" Grid.Row="0" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 2 -->
                                    <TextBlock Text="Voltage B-N" Grid.Row="1" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding VoltageB_N,StringFormat={}{0:F2}}" Grid.Row="1" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="V" Grid.Row="1" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 3 -->
                                    <TextBlock Text="Voltage C-N" Grid.Row="2" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding VoltageC_N,StringFormat={}{0:F2}}" Grid.Row="2" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="V" Grid.Row="2" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 4 -->
                                    <TextBlock Text="Voltage L-N Avg" Grid.Row="3" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding VoltageL_N_Avg,StringFormat={}{0:F2}}" Grid.Row="3" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="V" Grid.Row="3" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 5 -->
                                    <TextBlock Text="Current A" Grid.Row="4" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding CurrentA,StringFormat={}{0:F2}}" Grid.Row="4" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="A" Grid.Row="4" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 6 -->
                                    <TextBlock Text="Current B" Grid.Row="5" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding CurrentB,StringFormat={}{0:F2}}" Grid.Row="5" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="A" Grid.Row="5" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 7 -->
                                    <TextBlock Text="Current C" Grid.Row="6" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding CurrentC,StringFormat={}{0:F2}}" Grid.Row="6" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="A" Grid.Row="6" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 8 -->
                                    <TextBlock Text="Current Avg" Grid.Row="7" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding CurrentAvg,StringFormat={}{0:F2}}" Grid.Row="7" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="A" Grid.Row="7" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 9 -->
                                    <TextBlock Text="Total Active Power" Grid.Row="8" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding TotalActivePower,StringFormat={}{0:F2}}" Grid.Row="8" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="kW" Grid.Row="8" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 10 -->
                                    <TextBlock Text="Total Reactive Power" Grid.Row="9" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding TotalReactivePower,StringFormat={}{0:F2}}" Grid.Row="9" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="kVAR" Grid.Row="9" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 11 -->
                                    <TextBlock Text="Total Apparent Power" Grid.Row="10" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding TotalApparentPower,StringFormat={}{0:F2}}" Grid.Row="10" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="kVA" Grid.Row="10" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 12 -->
                                    <TextBlock Text="Frequency" Grid.Row="11" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding Frequency,StringFormat={}{0:F2}}" Grid.Row="11" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="Hz" Grid.Row="11" Grid.Column="2" FontSize="18" Foreground="White"/>

                                    <!-- Row 13 -->
                                    <TextBlock Text="Power Factor" Grid.Row="12" Foreground="Blue" FontSize="20"/>
                                    <TextBlock Text="{Binding TotalPowerFactor,StringFormat={}{0:F3}}" Grid.Row="12" Grid.Column="1" FontSize="18" Foreground="White"/>
                                    <TextBlock Text="PF" Grid.Row="12" Grid.Column="2" FontSize="18" Foreground="White"/>

                                </Grid>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>
        

        </ScrollViewer>

        <!-- Event Grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Events}"
                  AutoGenerateColumns="False">
            

            <DataGrid.Columns>

                <DataGridTextColumn Header="Time"
                                    Binding="{Binding Time}"/>

                <DataGridTextColumn Header="Source"
                                    Binding="{Binding Source}"/>

                <DataGridTextColumn Header="Message"
                                    Binding="{Binding Message}"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>
