<Window x:Class="IECGUI.View.RelayCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IECGUI.View"
        xmlns:controls="clr-namespace:IECGUI.Controls"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
       WindowStyle="None" ResizeMode="NoResize"
        Title="RelayCard" Height="350" Width="500">
    <Border Background="Transparent" BorderBrush="LightGreen" BorderThickness="5">
        <Grid>
            <TextBox Text="Incommer-1 Detail Card" FontSize="24" FontWeight="Bold" Foreground="Black"
                     Background="Transparent" BorderBrush="Transparent" HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Top" Margin="5" />
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />

            </Grid.RowDefinitions>
                <Grid Grid.Row="0" Grid.Column="1">
                    <Button  Content="X" HorizontalAlignment="Right" Foreground="OrangeRed" BorderBrush="Transparent" Background="Transparent" VerticalAlignment="Top" Width="20" Command="{Binding CloseCard}"/>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="0">
                    <controls:Indicator LampSize="55" LampColor="Red"  Label="3 L_01_0_R" IsOn="True"/>
                </Grid>
                
                <Grid Grid.Row="2" Grid.Column="0">
                    <controls:Indicator LampSize="55" LampColor="Red"   Label="4 L_01_0_R" IsOn="False"/>
                </Grid>

                <Grid Grid.Row="3" Grid.Column="0">
                    <controls:Indicator LampSize="55" LampColor="Red"   Label="5 L_01_0_R" IsOn="True"/>
                </Grid>

                <Grid Grid.Row="4" Grid.Column="0">
                    <controls:Indicator LampSize="55" LampColor="Red"   Label="6 L_01_0_R" IsOn="True"/>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">
                    <TextBox Text="Breaker Status" FontSize="20" BorderBrush="Transparent" HorizontalAlignment="Left" Margin="5"/>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="1">
                    <TextBox Text="Tripped Status" FontSize="20" BorderBrush="Transparent" HorizontalAlignment="Left" Margin="5"/>
                </Grid>

                <Grid Grid.Row="3" Grid.Column="1">
                    <TextBox Text="Spring Charge" FontSize="20" BorderBrush="Transparent" HorizontalAlignment="Left" Margin="5"/>
                </Grid>

                <Grid Grid.Row="4" Grid.Column="1">
                    <TextBox Text="Test Position" FontSize="20" BorderBrush="Transparent" HorizontalAlignment="Left" Margin="5"/>
                </Grid>
                
            </Grid>
        </Grid>
    </Border>
</Window>
